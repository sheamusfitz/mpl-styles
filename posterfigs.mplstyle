# Poster Style Sheet Configuration

# Fonts
font.size: 10
axes.titlesize: 16
axes.labelsize: 15
xtick.labelsize: 12
ytick.labelsize: 12
legend.fontsize: 12
figure.titlesize: 16

# Legend
legend.frameon: True
legend.edgecolor: black
legend.fancybox: False

# Figure Layout
figure.autolayout: True
figure.dpi: 300
