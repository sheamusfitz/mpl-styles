# Poster Style Sheet Configuration

# Fonts
font.size: 12
axes.titlesize: 19
axes.labelsize: 17
xtick.labelsize: 15
ytick.labelsize: 15
legend.fontsize: 11
figure.titlesize: 19

# Legend
legend.frameon: True
legend.edgecolor: black
legend.fancybox: False

# Figure Layout
figure.autolayout: True
figure.dpi: 300
